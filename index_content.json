{"content": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>2026世界杯预测报告 · 每日更新</title>\n<style>\n  * { box-sizing: border-box; margin:0; padding:0; }\n  body { font-family: -apple-system,\"PingFang SC\",\"Microsoft YaHei\",sans-serif; background:#f5f7fa; color:#1a1a2e; line-height:1.7; }\n  .header { background:linear-gradient(135deg,#0033A0,#1a4fc4); color:white; padding:28px 24px 24px; text-align:center; }\n  .header h1 { font-size:22px; font-weight:700; letter-spacing:1px; }\n  .header p { font-size:13px; opacity:0.85; margin-top:6px; }\n  .nav { background:white; padding:10px 24px; box-shadow:0 2px 8px rgba(0,0,0,0.06); display:flex; gap:12px; flex-wrap:wrap; justify-content:center; }\n  .nav a { font-size:13px; padding:6px 16px; border-radius:20px; text-decoration:none; font-weight:600; transition:all 0.2s; }\n  .nav a.active { background:#0033A0; color:white; }\n  .nav a:not(.active) { background:#f0f4ff; color:#0033A0; }\n  .nav a:not(.active):hover { background:#d0dffa; }\n  .container { max-width:900px; margin:0 auto; padding:24px 16px 48px; }\n  .welcome { background:white; border-radius:10px; box-shadow:0 2px 12px rgba(0,0,0,0.06); padding:28px; margin-bottom:20px; text-align:center; }\n  .welcome h2 { color:#0033A0; margin-bottom:8px; font-size:18px; }\n  .welcome p { color:#666; font-size:14px; }\n  .report-frame { background:white; border-radius:10px; box-shadow:0 2px 12px rgba(0,0,0,0.06); margin-bottom:20px; overflow:hidden; }\n  .report-frame iframe { width:100%; height:800px; border:none; }\n  .report-frame .loading { text-align:center; padding:40px; color:#888; font-size:14px; }\n  .history-section { background:white; border-radius:10px; box-shadow:0 2px 12px rgba(0,0,0,0.06); padding:24px; }\n  .history-title { font-size:15px; font-weight:700; color:#0033A0; border-left:4px solid #0033A0; padding-left:12px; margin-bottom:16px; }\n  .history-list { display:flex; flex-direction:column; gap:10px; }\n  .history-item { display:flex; align-items:center; gap:14px; padding:12px 16px; background:#f8fafd; border-radius:8px; text-decoration:none; color:inherit; transition:background 0.2s; }\n  .history-item:hover { background:#e8f0fe; }\n  .history-date { font-size:13px; font-weight:700; color:#0033A0; min-width:100px; }\n  .history-match { font-size:14px; flex:1; }\n  .history-result { font-size:12px; padding:2px 10px; border-radius:4px; font-weight:600; }\n  .tag-ok { background:#e8f5e9; color:#2e7d32; }\n  .footer { text-align:center; font-size:11px; color:#aaa; padding:20px; border-top:1px solid #eee; margin-top:24px; }\n  .empty-state { text-align:center; padding:60px 20px; color:#888; }\n  .empty-state .icon { font-size:48px; margin-bottom:12px; }\n  @media (max-width:600px) { .history-item { flex-direction:column; align-items:flex-start; gap:6px; } }\n</style>\n</head>\n<body>\n\n<div class=\"header\">\n  <h1>2026 FIFA 世界杯 · 每日预测报告</h1>\n  <p>自动更新 · 数据驱动 · 多维度分析</p>\n</div>\n\n<div class=\"nav\">\n  <a href=\"index.html\" class=\"active\">最新报告</a>\n  <a href=\"#history\">历史报告</a>\n  <a href=\"about.html\">关于</a>\n</div>\n\n<div class=\"container\">\n\n  <div class=\"welcome\">\n    <h2 id=\"latest-title\">正在加载最新报告…</h2>\n    <p id=\"latest-subtitle\">请稍候</p>\n  </div>\n\n  <div class=\"report-frame\" id=\"report-frame\">\n    <div class=\"loading\" id=\"loading-msg\">正在加载报告内容…</div>\n    <iframe id=\"report-iframe\" style=\"display:none;\"></iframe>\n  </div>\n\n  <div class=\"history-section\" id=\"history\">\n    <div class=\"history-title\">历史报告存档</div>\n    <div class=\"history-list\" id=\"history-list\">\n      <div class=\"empty-state\">\n        <div class=\"icon\">📭</div>\n        <div>暂无历史报告，请稍后查看</div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"footer\">\n    本页由 WorkBuddy AI 自动生成 ｜ 每日 18:00 自动更新 ｜ 报告数据仅供参考，不构成投注建议\n  </div>\n\n</div>\n\n<script>\n  var REPORTS = [\n    {\n      date: \"2026-06-12\",\n      file: \"reports/report-2026-06-12.html\",\n      title: \"韩国 vs 捷克\",\n      group: \"A组 小组赛\",\n      prediction: \"1-1\",\n      confidence: \"中\"\n    }\n  ];\n\n  function renderLatest() {\n    if (REPORTS.length === 0) return;\n    var latest = REPORTS[0];\n    document.getElementById(\"latest-title\").textContent = \"最新报告：\" + latest.title;\n    document.getElementById(\"latest-subtitle\").textContent = latest.group + \" · 预测 \" + latest.prediction + \" · 置信度 \" + latest.confidence;\n    var iframe = document.getElementById(\"report-iframe\");\n    iframe.src = latest.file;\n    iframe.style.display = \"block\";\n    document.getElementById(\"loading-msg\").style.display = \"none\";\n  }\n\n  function renderHistory() {\n    if (REPORTS.length <= 1) return;\n    var list = document.getElementById(\"history-list\");\n    list.innerHTML = \"\";\n    REPORTS.slice(1).forEach(function(r) {\n      var item = document.createElement(\"a\");\n      item.className = \"history-item\";\n      item.href = r.file;\n      item.innerHTML = '<div class=\"history-date\">' + r.date + '</div><div class=\"history-match\">' + r.title + ' <span style=\"color:#888;font-size:12px;\">（' + r.group + '）</span></div><div class=\"history-result tag-ok\">预测 ' + r.prediction + '</div>';\n      list.appendChild(item);\n    });\n  }\n\n  document.addEventListener(\"DOMContentLoaded\", function() {\n    renderLatest();\n    renderHistory();\n  });\n</script>\n\n</body>\n</html>"}